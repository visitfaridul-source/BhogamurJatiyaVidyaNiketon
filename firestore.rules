rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Checking if the signed-in user is a pre-authorized master admin
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'EepWyaNAChdn3aOYhkR2u6ME7pv1' ||
        (request.auth.token != null && 'email' in request.auth.token && (
          request.auth.token.email == 'bjvnhs@gmail.com' ||
          request.auth.token.email == 'visitfaridul@gmail.com' ||
          request.auth.token.email == 'BJVNHS@GMAIL.COM' ||
          request.auth.token.email == 'VISITFARIDUL@GMAIL.COM'
        ))
      );
    }

    // Check if user is a Database-defined Admin
    function isDbAdmin(uid) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(uid)) && (
               'role' in get(/databases/$(database)/documents/users/$(uid)).data && (
                 get(/databases/$(database)/documents/users/$(uid)).data.role == 'Super Admin' || 
                 get(/databases/$(database)/documents/users/$(uid)).data.role == 'Admin'
               )
             );
    }

    // Master Override: Super Admins (including bjvnhs@gmail.com / visitfaridul@gmail.com)
    // have total write, read, delete, and update capabilities across all collections.
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // Individual collection rules to allow read/write for other roles as appropriate
    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId ||
        isSuperAdmin() ||
        isDbAdmin(request.auth.uid)
      );

      allow write: if isSignedIn() && (
        isSuperAdmin() ||
        (request.auth.uid == userId && (
          // If the profile does not exist yet (create operation)
          (resource == null && (
            request.resource.data.get('role', 'Student') == 'Student' || 
            request.resource.data.get('role', '') == 'Teacher' || 
            request.resource.data.get('role', '') == 'Parent' ||
            ((request.resource.data.get('role', '') == 'Super Admin' || request.resource.data.get('role', '') == 'Admin') && isSuperAdmin())
          )) ||
          // If profile exists (update operation), prevent role modifications for non-admins
          (resource != null && 
           request.resource.data.get('role', '') == resource.data.get('role', ''))
        )) ||
        isDbAdmin(request.auth.uid)
      );
    }
    
    match /students/{studentId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || (isSignedIn() && isDbAdmin(request.auth.uid));
    }
    
    match /teachers/{teacherId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || (isSignedIn() && isDbAdmin(request.auth.uid));
    }

    match /onlineAdmissions/{admissionId} {
      allow create: if true;
      allow read, update, delete: if isSuperAdmin() || (isSignedIn() && isDbAdmin(request.auth.uid));
    }

    match /results/{resultId} {
      allow read: if true;
      allow write: if isSuperAdmin() || (isSignedIn() && isDbAdmin(request.auth.uid));
    }

    match /sessions/{sessionId} {
      allow read: if true;
      allow write: if isSuperAdmin() || (isSignedIn() && isDbAdmin(request.auth.uid));
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if isSuperAdmin() || (isSignedIn() && isDbAdmin(request.auth.uid));
    }

    match /settings/{settingsId} {
      allow read: if true;
      allow write: if isSuperAdmin() || (isSignedIn() && isDbAdmin(request.auth.uid));
    }
  }
}

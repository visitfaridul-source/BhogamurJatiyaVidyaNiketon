rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Private administrative collections - Require authentication
    match /students/{docId} {
      allow read, write: if request.auth != null;
    }
    match /teachers/{docId} {
      allow read, write: if request.auth != null;
    }
    match /attendance/{docId} {
      allow read, write: if request.auth != null;
    }
    match /fees/{docId} {
      allow read, write: if request.auth != null;
    }
    match /users/{docId} {
      allow read, write: if request.auth != null;
    }

    // 2. Online Admission Form Submissions - Anyone can create, only authenticated can read/list/delete
    match /onlineAdmissions/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // 3. Public website content - Anyone can read, only authenticated can write
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /courses/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /sessions/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /results/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /events/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Global fallback
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}

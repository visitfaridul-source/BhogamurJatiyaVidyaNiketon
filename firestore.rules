rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net (Default-deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Checking if a user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Check if the authenticated user has a bootstrapped admin email or known admin UID
    function isEmailAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'EepWyaNAChdn3aOYhkR2u6ME7pv1' ||
        (request.auth.token != null && 
         'email' in request.auth.token && (
           request.auth.token.email.lower() == 'visitfaridul@gmail.com' || 
           request.auth.token.email.lower() == 'bjvnhs@gmail.com'
         )
        )
      );
    }

    // Check if user is a Database-defined Admin
    function isDbAdmin(uid) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(uid)) && (
               get(/databases/$(database)/documents/users/$(uid)).data.get('role', '') == 'Super Admin' || 
               get(/databases/$(database)/documents/users/$(uid)).data.get('role', '') == 'Admin'
             );
    }

    // Users Collection rules
    match /users/{userId} {
      // Allow user to read their own profile immediately, or admins to read any profile
      allow read: if isSignedIn() && (
        request.auth.uid == userId ||
        isEmailAdmin() ||
        (request.auth.uid != userId && isDbAdmin(request.auth.uid))
      );

      allow write: if isSignedIn() && (
        isEmailAdmin() ||
        (request.auth.uid == userId && (
          // If the profile does not exist yet (create operation)
          (resource == null && (
            request.resource.data.role == 'Student' || 
            request.resource.data.role == 'Teacher' || 
            request.resource.data.role == 'Parent' ||
            (request.resource.data.role == 'Super Admin' && isEmailAdmin())
          )) ||
          // If profile exists (update operation), prevent role modifications for non-admins
          (resource != null && 
           request.resource.data.role == resource.data.role)
        )) ||
        (request.auth.uid != userId && isDbAdmin(request.auth.uid))
      );
    }
    
    // Students Collection rules
    match /students/{studentId} {
      allow read: if isSignedIn();
      allow write: if isEmailAdmin() || (isSignedIn() && isDbAdmin(request.auth.uid));
    }
    
    // Teachers Collection rules
    match /teachers/{teacherId} {
      allow read: if isSignedIn();
      allow write: if isEmailAdmin() || (isSignedIn() && isDbAdmin(request.auth.uid));
    }

    // Online Admissions rules
    match /onlineAdmissions/{admissionId} {
      allow create: if true;
      allow read, update, delete: if isEmailAdmin() || (isSignedIn() && isDbAdmin(request.auth.uid));
    }

    // Student Results rules
    match /results/{resultId} {
      allow read: if true;
      allow write: if isEmailAdmin() || (isSignedIn() && isDbAdmin(request.auth.uid));
    }

    // Academic Sessions rules
    match /sessions/{sessionId} {
      allow read: if true;
      allow write: if isEmailAdmin() || (isSignedIn() && isDbAdmin(request.auth.uid));
    }

    // Courses rules
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isEmailAdmin() || (isSignedIn() && isDbAdmin(request.auth.uid));
    }

    // Website Settings rules
    match /settings/{settingsId} {
      allow read: if true;
      allow write: if isEmailAdmin() || (isSignedIn() && isDbAdmin(request.auth.uid));
    }
  }
}

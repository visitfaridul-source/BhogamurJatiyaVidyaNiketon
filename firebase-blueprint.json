{
  "entities": {
    "Student": {
      "title": "Student",
      "description": "A student in the school",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "class": { "type": "string" },
        "section": { "type": "string" },
        "roll": { "type": "string" },
        "parentName": { "type": "string" },
        "phone": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "Teacher": {
      "title": "Teacher",
      "description": "A teacher in the school",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "subject": { "type": "string" },
        "qualification": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "OnlineAdmissionForm": {
      "title": "OnlineAdmissionForm",
      "description": "An online admission form application",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "submitDate": { "type": "string" },
        "name": { "type": "string" },
        "class": { "type": "string" },
        "dob": { "type": "string" },
        "parentName": { "type": "string" },
        "motherName": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "aadhaar": { "type": "string" },
        "pen": { "type": "string" },
        "apaar": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "StudentResult": {
      "title": "StudentResult",
      "description": "A student result marksheet",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "className": { "type": "string" },
        "examName": { "type": "string" },
        "totalMarks": { "type": "number" },
        "percentage": { "type": "number" },
        "grade": { "type": "string" },
        "status": { "type": "string" },
        "remarks": { "type": "string" }
      }
    },
    "AcademicSession": {
      "title": "AcademicSession",
      "description": "An academic year/session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "isActive": { "type": "boolean" }
      }
    },
    "Course": {
      "title": "Course",
      "description": "A class subject course with study materials",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "class": { "type": "string" },
        "subject": { "type": "string" }
      }
    },
    "AttendanceRecord": {
      "title": "AttendanceRecord",
      "description": "An attendance entry for a student or staff in format date_id",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string" },
        "remarks": { "type": "string" },
        "inTime": { "type": "string" },
        "outTime": { "type": "string" },
        "earlyOutReason": { "type": "string" }
      }
    },
    "FeeTransaction": {
      "title": "FeeTransaction",
      "description": "A student fee transaction payment receipt record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "class": { "type": "string" },
        "type": { "type": "string" },
        "date": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "SchoolEvent": {
      "title": "SchoolEvent",
      "description": "An event on the school calendar dynamic dashboard tracker",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string" },
        "type": { "type": "string" }
      }
    },
    "RegisteredFace": {
      "title": "RegisteredFace",
      "description": "A pre-registered face record for a student, teacher, or staff member",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "registered": { "type": "boolean" },
        "registeredAt": { "type": "string" }
      },
      "required": ["id"]
    },
    "WebsiteSettings": {
      "title": "WebsiteSettings",
      "description": "Live custom layout configurations and static page variables",
      "type": "object",
      "properties": {
        "schoolName": { "type": "string" },
        "heroHeadline": { "type": "string" },
        "heroSubtitle": { "type": "string" }
      }
    }
  },
  "firestore": {
    "students": {
      "schema": "Student",
      "description": "Students collection"
    },
    "teachers": {
      "schema": "Teacher",
      "description": "Teachers collection"
    },
    "onlineAdmissions": {
      "schema": "OnlineAdmissionForm",
      "description": "Online admissions requests collection"
    },
    "results": {
      "schema": "StudentResult",
      "description": "Results published for lookup"
    },
    "sessions": {
      "schema": "AcademicSession",
      "description": "School academic sessions"
    },
    "courses": {
      "schema": "Course",
      "description": "Class courses lists and materials"
    },
    "settings": {
      "schema": "WebsiteSettings",
      "description": "Generic website settings documents collection"
    },
    "attendance": {
      "schema": "AttendanceRecord",
      "description": "Attendance registry entries"
    },
    "fees": {
      "schema": "FeeTransaction",
      "description": "Fee payment transactions"
    },
    "events": {
      "schema": "SchoolEvent",
      "description": "School calendar events"
    },
    "registeredFaces": {
      "schema": "RegisteredFace",
      "description": "Faces pre-registered for the face scanner"
    }
  }
}
